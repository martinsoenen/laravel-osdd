{
    "name": "{{ name }}",
    "description": "",
    "type": "layer",
    "version": "1.0.0",
    "require": {
        "xefi/laravel-osdd": "*"
    },
    "autoload": {
        "psr-4": {
            "{{ namespace }}\\": "src/",
            "{{ namespace }}\\Database\\Seeders\\": "database/seeders/",
            "{{ namespace }}\\Database\\Factories\\": "database/factories/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
